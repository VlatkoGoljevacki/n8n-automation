# n8n server
N8N_PORT=5678
N8N_SECURE_COOKIE=false
N8N_API_KEY=your-n8n-api-key-here
N8N_ACCESSIBLE_ENV_VARS=MEDIKA_ERP_URL,MEDIKA_ERP_USERNAME,MEDIKA_ERP_PASSWORD,OPENAI_API_KEY,MS_GRAPH_TENANT_ID,MS_GRAPH_CLIENT_ID,MS_GRAPH_CLIENT_SECRET

# SQLite
DB_SQLITE_POOL_SIZE=2
DB_SQLITE_VACUUM_ON_STARTUP=false

# Timezone
GENERIC_TIMEZONE=Europe/Zagreb
TZ=Europe/Zagreb

# External runners
N8N_RUNNERS_AUTH_TOKEN=change-me-to-a-random-secret
N8N_RUNNERS_MAX_CONCURRENCY=10
N8N_RUNNERS_TASK_TIMEOUT=600

# Execution history (hours — 8760 = 1 year)
EXECUTIONS_DATA_MAX_AGE=8760

# OpenAI (AI-assisted XLSX parsing)
OPENAI_API_KEY=sk-...

# Google Places API
PLACES_API=your-google-places-api-key

# Medika ERP API — production
MEDIKA_ERP_URL=https://nar.medika.hr
MEDIKA_ERP_USERNAME=your-prod-erp-username
MEDIKA_ERP_PASSWORD=your-prod-erp-password

# Medika ERP API — test (used by test-namespace workflows)
MEDIKA_ERP_URL_TEST=https://testnar.medika.hr
MEDIKA_ERP_USERNAME_TEST=your-test-erp-username
MEDIKA_ERP_PASSWORD_TEST=your-test-erp-password

# Microsoft Graph API — shared credentials (same Azure app for both envs)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Microsoft Graph mailboxes — production
MS_GRAPH_MAILBOX_READ=
MS_GRAPH_MAILBOX_SEND=

# Microsoft Graph mailboxes — test
MS_GRAPH_MAILBOX_READ_TEST=
MS_GRAPH_MAILBOX_SEND_TEST=
