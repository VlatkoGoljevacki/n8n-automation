# Workflow variable substitution — PROD environment
# Copy to .env.workflow.prod and fill in your production server's values.
# The deploy script replaces %%VAR%% placeholders at deploy time.

# DataTable IDs (find via: ./helpers/datatables.sh list)
DT_CUSTOMERS_ID=
DT_TOKENS_ID=

# Microsoft Graph mail folder IDs — PROD folders
# (find via Graph Explorer: GET /users/{mailbox}/mailFolders)
MS_FOLDER_PROCESSING_ID=
MS_FOLDER_PROCESSED_ID=
MS_FOLDER_ERROR_ID=
MS_FOLDER_PARTIAL_ID=
