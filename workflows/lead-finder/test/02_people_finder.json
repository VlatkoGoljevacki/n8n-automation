    {
      "parameters": {
        "jsCode": "// Combine results from all search sub-workflows\n// Each sub-workflow returns { results: [...] }\n// Gracefully handle missing/failed sub-workflows\nconst businessInput = $('Loop Businesses').item.json;\nconst allResults = [];\n\n// Collect from Serper\ntry {\n  const serper = $('WF-02b: Serper Search').first().json;\n  if (serper.results) allResults.push(...serper.results);\n} catch(e) { /* sub-workflow not available or failed */ }\n\n// Collect from OpenAI\ntry {\n  const openai = $('WF-02d: OpenAI Search').first().json;\n  if (openai.results) allResults.push(...openai.results);\n} catch(e) { /* sub-workflow not available or failed */ }\n\n// Future: add SerpApi and Hunter search results here\n\nreturn [{\n  json: {\n    businessName: businessInput.businessName,\n    website: businessInput.website,\n    region: businessInput.region,\n    country: businessInput.country,\n    row_number: businessInput.row_number,\n    searchResults: allResults,\n    resultCount: allResults.length\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
        0
      ],
      "id": "lf-02-0000-0000-000000000011",
      "name": "Combine Results"
    },
    {
      "parameters": {
        "resource": "chat"
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        2016,
        0
