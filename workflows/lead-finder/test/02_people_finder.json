      "id": "lf-02-0000-0000-000000000012",
      "name": "Extract Contacts",
      "credentials": {
        "openAiApi": {
          "id": "eD10IPhcxdI4yu0p",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse OpenAI response into individual contact items for sheet append\nconst input = $input.first().json;\nconst combinedData = $('Combine Results').first().json;\nconst businessName = combinedData.businessName;\n\n// Extract the text response from OpenAI\nconst responseText = input.output?.[0]?.content?.[0]?.text || input.message?.content || JSON.stringify(input);\n\n// Parse JSON from response (handle markdown fences)\nlet contacts = [];\ntry {\n  let jsonStr = responseText;\n  // Strip markdown code fences\n  const fenceMatch = jsonStr.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n  if (fenceMatch) jsonStr = fenceMatch[1];\n  jsonStr = jsonStr.trim();\n  \n  const parsed = JSON.parse(jsonStr);\n  contacts = Array.isArray(parsed) ? parsed : [parsed];\n} catch(e) {\n  // If parsing fails, return empty\n  return [];\n}\n\nif (contacts.length === 0) return [];\n\nreturn contacts.map(c => ({\n  json: {\n    businessName: businessName,\n    name: c.name || '',\n    title: c.title || '',\n    email: c.email || '',\n    phone: c.phone || '',\n    linkedin: c.linkedin || '',\n    facebook: c.facebook || '',\n    instagram: c.instagram || '',\n    twitter: c.twitter || '',\n    source: 'serper+openai',\n    verified: 'pending',\n    verificationDate: '',\n    lastUpdated: new Date().toISOString().split('T')[0]\n  }\n}));"
      },
