    {
      "parameters": {
        "jsCode": "// Prepare standard input for sub-workflows\n// Each business becomes a standardized search request\nconst businesses = $input.all();\nconst config = $('People Finder Config').first().json;\n\nreturn businesses.map(biz => ({\n  json: {\n    businessName: biz.json['Name'],\n    website: biz.json['Website'] || '',\n    region: biz.json['Region'] || '',\n    country: config.country,\n    phone: biz.json['Phone'] || '',\n    address: biz.json['Address'] || '',\n    googlePlaceId: biz.json['Google Place ID'] || '',\n    row_number: biz.json['row_number']\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        0
      ],
      "id": "lf-02-0000-0000-000000000007",
