    {
      "parameters": {
        "jsCode": "// Read accumulated counts from staticData and produce one item per region\nconst staticData = $getWorkflowStaticData('global');\nconst regionCounts = staticData.regionCounts || {};\n\n// Build output for each region\nconst results = Object.entries(regionCounts).map(([region, count]) => ({\n  json: {\n    regionName: region,\n    unique: count\n  }\n}));\n\n// Clean up staticData for next run\ndelete staticData.regionCounts;\n\nreturn results.length > 0 ? results : [{ json: { regionName: 'unknown', unique: 0 } }];"
      },
