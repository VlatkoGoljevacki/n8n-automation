    {
      "parameters": {
        "jsCode": "// Build ALL search queries upfront: regions × search terms\nconst regions = $input.all();\nconst config = $('Hotels Niche config').first().json;\nconst country = config.country;\nconst searchTerms = config.searchTerms.split(',').map(s => s.trim());\n\nconst queries = [];\nfor (const region of regions) {\n  const regionName = region.json['Region Name'];\n  for (const term of searchTerms) {\n    queries.push({\n      json: {\n        searchTerm: term,\n        query: `${term} in ${regionName}, ${country}`,\n        regionName: regionName,\n        regionType: region.json['Region Type'],\n        rowNumber: region.json['row_number']\n      }\n    });\n  }\n}\n\nreturn queries;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "id": "lf-01-0000-0000-000000000006",
      "name": "Build All Queries"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        896,
        0
      ],
      "id": "lf-01-0000-0000-000000000007",
      "name": "Loop Queries"
    },
    {
      "parameters": {
        "jsCode": "// Search Google Places with pagination, track counts in staticData\nconst query = $input.first().json.query;\nconst regionName = $input.first().json.regionName;\nconst apiKey = $env.PLACES_API;\nconst fieldMask = 'places.id,places.displayName,places.formattedAddress,places.nationalPhoneNumber,places.websiteUri,places.rating,places.types,places.googleMapsUri,nextPageToken';\n\nconst allPlaces = [];\nlet pageToken = null;\nlet page = 0;\n\ndo {\n  const body = { textQuery: query, languageCode: 'en' };\n  if (pageToken) body.pageToken = pageToken;\n\n  const response = await this.helpers.httpRequest({\n    method: 'POST',\n    url: 'https://places.googleapis.com/v1/places:searchText',\n    headers: {\n      'Content-Type': 'application/json',\n      'X-Goog-Api-Key': apiKey,\n      'X-Goog-FieldMask': fieldMask\n    },\n    body: JSON.stringify(body)\n  });\n\n  const data = typeof response === 'string' ? JSON.parse(response) : response;\n  const places = data.places || [];\n  allPlaces.push(...places);\n\n  pageToken = data.nextPageToken || null;\n  page++;\n\n  if (pageToken) {\n    await new Promise(resolve => setTimeout(resolve, 2000));\n  }\n} while (pageToken && page < 10);\n\n// Track counts per region in staticData (survives across loop iterations)\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.regionCounts) staticData.regionCounts = {};\nif (!staticData.regionCounts[regionName]) staticData.regionCounts[regionName] = 0;\nstaticData.regionCounts[regionName] += allPlaces.length;\n\nif (allPlaces.length === 0) {\n  return [];\n}\n\nreturn allPlaces.map(p => ({\n  json: {\n    googlePlaceId: p.id || '',\n    name: p.displayName?.text || '',\n    type: (p.types || []).find(t =>\n      ['hotel', 'resort', 'lodging', 'campground', 'hostel'].some(k => t.includes(k))\n    ) || 'lodging',\n    region: regionName,\n    address: p.formattedAddress || '',\n    phone: p.nationalPhoneNumber || '',\n    email: '',\n    website: p.websiteUri || '',\n    rating: p.rating || '',\n    googleMapsUrl: p.googleMapsUri || '',\n    peopleStatus: 'pending',\n    lastUpdated: new Date().toISOString().split('T')[0]\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
