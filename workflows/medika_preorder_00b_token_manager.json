      "id": "f0b00000-0000-4000-8000-000000000002",
      "name": "DT: Read Token",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Check Data Table for a valid cached ERP token\nconst config = $('Config').first().json;\nconst erpApiUrl = config.erpApiUrl;\nconst erpUsername = config.erpUsername;\nconst erpPassword = config.erpPassword;\n\n// Find latest valid token from DT results\nconst dtRows = $('DT: Read Token').all();\nlet latestToken = null;\nlet latestStoredAt = 0;\n\nfor (const row of dtRows) {\n  const r = row.json;\n  if (!r.token || !r.expiresAt) continue;\n\n  const storedAt = r.storedAt ? new Date(r.storedAt).getTime() : 0;\n  if (storedAt > latestStoredAt) {\n    latestStoredAt = storedAt;\n    latestToken = r;\n  }\n}\n\n// Check if latest token is still valid (5-min buffer)\nif (latestToken) {\n  const bufferMs = 5 * 60 * 1000;\n  const expiresAt = new Date(latestToken.expiresAt).getTime();\n  if (Date.now() < (expiresAt - bufferMs)) {\n    return [{ json: {\n      needsFetch: false,\n      accessToken: latestToken.token,\n      expiresAt: latestToken.expiresAt\n    }}];\n  }\n}\n\n// Token missing or expired — prepare fetch\nreturn [{ json: {\n  needsFetch: true,\n  tokenUrl: erpApiUrl + '/Token',\n  tokenBody: 'grant_type=password&username=' + encodeURIComponent(erpUsername) + '&password=' + encodeURIComponent(erpPassword)\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        0
      ],
      "id": "f0b00000-0000-4000-8000-000000000003",
      "name": "Check Token"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "f0b00003-0000-4000-8000-000000000001",
              "leftValue": "={{ $json.needsFetch }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "false"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        720,
        0
      ],
      "id": "f0b00000-0000-4000-8000-000000000004",
      "name": "Token Valid?"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Return cached token from Data Table\nconst checked = $input.first().json;\n\nreturn [{ json: {\n  accessToken: checked.accessToken,\n  expiresAt: checked.expiresAt,\n  cacheHit: true\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        -96
      ],
      "id": "f0b00000-0000-4000-8000-000000000005",
