            }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ $json.tokenBody }}",
        "options": {
          "timeout": 15000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        208
      ],
      "id": "f0b00000-0000-4000-8000-000000000006",
      "name": "Fetch Token"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Parse ERP token response and format for Data Table storage\nconst tokenResponse = $input.first().json;\nconst token = tokenResponse.access_token;\nif (!token) {\n  throw new Error('Failed to get ERP token: ' + JSON.stringify(tokenResponse));\n}\n\nlet expiresAt;\nif (tokenResponse['.expires']) {\n  expiresAt = new Date(tokenResponse['.expires']).toISOString();\n} else if (tokenResponse.expires_in) {\n  expiresAt = new Date(Date.now() + (tokenResponse.expires_in * 1000)).toISOString();\n} else {\n  expiresAt = new Date(Date.now() + (60 * 60 * 1000)).toISOString();\n}\n\nreturn [{ json: {\n  token: token,\n  expiresAt: expiresAt,\n  storedAt: new Date().toISOString(),\n  accessToken: token\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        208
      ],
      "id": "f0b00000-0000-4000-8000-000000000007",
      "name": "Parse Token"
    },
    {
