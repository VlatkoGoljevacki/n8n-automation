    {
      "parameters": {
        "jsCode": "// Convert Graph API message with expanded attachments to n8n format\nconst message = $input.first().json;\nconst attachments = message.attachments || [];\nconst binary = {};\n\nfor (let i = 0; i < attachments.length; i++) {\n  const att = attachments[i];\n  if (att.contentBytes) {\n    binary['attachment_' + i] = {\n      data: att.contentBytes,\n      mimeType: att.contentType || 'application/octet-stream',\n      fileName: att.name || 'attachment_' + i,\n      fileSize: att.size || 0\n    };\n  }\n}\n\nconst { attachments: _, ...messageJson } = message;\n\nreturn [{ json: messageJson, binary }];\n"
      },
