      "parameters": {
        "jsCode": "// Consolidate data for WF-09 — XLSX loop iteration\nconst parseResult = $input.first().json;\nconst loopItem = $('Loop Over XLSX Files').first().json;\nconst loopBinary = $('Loop Over XLSX Files').first().binary || {};\nconst binary = {};\nif (loopBinary.data) binary.data = loopBinary.data;\n\nreturn [{\n  json: {\n    ...parseResult,\n    emailId: loopItem.emailId,\n    senderEmail: loopItem.senderEmail,\n    emailSubject: loopItem.emailSubject,\n    receivedAt: loopItem.receivedAt,\n    config: loopItem.config,\n    accessToken: loopItem.accessToken,\n    emailBody: loopItem.emailBody,\n    emailBodyHtml: (loopItem.emailBody || {}).content || '',\n    skipEmailMove: true,\n    xlsxFileName: loopItem.xlsxFileName || ''\n  },\n  binary\n}];\n"
