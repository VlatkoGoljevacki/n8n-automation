    },
    {
      "parameters": {
        "jsCode": "// Aggregate all XLSX processing results after loop completes\nconst staticData = $getWorkflowStaticData('global');\nconst results = staticData.orderResults || [];\n\nconst successCount = results.filter(r => r.success).length;\nconst failCount = results.filter(r => !r.success).length;\nconst totalCount = results.length;\n\nlet overallStatus;\nif (failCount === 0) overallStatus = 'success';\nelse if (successCount === 0) overallStatus = 'error';\nelse overallStatus = 'partial';\n\ndelete staticData.orderResults;\n\nreturn [{\n  json: {\n    emailId: staticData.emailId,\n    senderEmail: staticData.senderEmail,\n    emailSubject: staticData.emailSubject,\n    config: staticData.config,\n    overallStatus,\n    successCount,\n    failCount,\n    totalCount,\n    results,\n    hasAnySuccess: successCount > 0\n  }\n}];\n"
      },
