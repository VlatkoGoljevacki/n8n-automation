    {
      "parameters": {
        "jsCode": "// Build warning email summarizing XLSX processing failures\nconst agg = $('Aggregate Results').first().json;\nconst config = agg.config || {};\nconst failures = agg.results.filter(r => !r.success);\n\nlet failureRows = '';\nfor (const f of failures) {\n  failureRows += '<tr>'\n    + '<td style=\"padding: 8px; border: 1px solid #ddd;\">' + (f.xlsxFileName || 'Unknown') + '</td>'\n    + '<td style=\"padding: 8px; border: 1px solid #ddd;\">' + (f.error || 'Unknown error') + '</td>'\n    + '</tr>';\n}\n\nconst isTotal = agg.successCount === 0;\nconst heading = isTotal ? 'Neuspjeh obrade narudžbe' : 'Djelomični neuspjeh obrade narudžbe';\nconst headingColor = isTotal ? '#c0392b' : '#d35400';\n\nconst html = '<div style=\"font-family: Arial, sans-serif; max-width: 600px;\">'\n  + '<h2 style=\"color: ' + headingColor + ';\">' + heading + '</h2>'\n  + '<p>' + agg.successCount + ' od ' + agg.totalCount + ' XLSX datoteka uspješno obrađeno. '\n  + agg.failCount + ' neuspjelo:</p>'\n  + '<table style=\"border-collapse: collapse; width: 100%; margin: 16px 0;\">'\n  + '<tr><th style=\"padding: 8px; border: 1px solid #ddd; text-align: left;\">Datoteka</th>'\n  + '<th style=\"padding: 8px; border: 1px solid #ddd; text-align: left;\">Greška</th></tr>'\n  + failureRows\n  + '</table>'\n  + '<table style=\"border-collapse: collapse; width: 100%; margin: 16px 0;\">'\n  + '<tr><td style=\"padding: 8px; border: 1px solid #ddd; font-weight: bold;\">Od</td>'\n  + '<td style=\"padding: 8px; border: 1px solid #ddd;\">' + agg.senderEmail + '</td></tr>'\n  + '<tr><td style=\"padding: 8px; border: 1px solid #ddd; font-weight: bold;\">Predmet</td>'\n  + '<td style=\"padding: 8px; border: 1px solid #ddd;\">' + agg.emailSubject + '</td></tr>'\n  + '</table>'\n  + '</div>';\n\nconst subjectPrefix = isTotal ? '[Medika] Neuspjeh' : '[Medika] Djelomični neuspjeh';\nconst subject = subjectPrefix + ' - ' + agg.emailSubject;\nconst message = {\n  subject,\n  body: { contentType: 'HTML', content: html },\n  toRecipients: (config.notifyEmail || '').split(',').map(e => ({ emailAddress: { address: e.trim() } }))\n};\n\nreturn [{ json: { sendMailPayload: { message } } }];\n"
      },
