        "jsCode": "// Record successful order processing and loop back\nconst staticData = $getWorkflowStaticData('global');\nconst loopItem = $('Loop Over XLSX Files').first().json;\nconst wf09Result = $input.first().json || {};\n\nstaticData.orderResults = staticData.orderResults || [];\nstaticData.orderResults.push({\n  xlsxFileName: loopItem.xlsxFileName || '',\n  xlsxIndex: loopItem.xlsxIndex,\n  success: true,\n  orderResult: wf09Result\n});\n\nreturn [{ json: { recorded: true } }];"
