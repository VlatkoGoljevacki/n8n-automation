        "jsCode": "const submissionResult = $input.first().json;\nconst submissionInput = $('Prepare Submission Input').first().json;\nconst subInput = $('Sub-Workflow Input').first().json;\nconst config = subInput.config;\n\nconst binary = $('Sub-Workflow Input').first().binary || {};\n\nreturn [{\n  json: {\n    config: config,\n    submissionResult: submissionResult,\n    validatedLines: submissionInput.validatedLines,\n    invalidLines: submissionInput.invalidLines,\n    summary: submissionInput.summary,\n    lineCount: submissionInput.lineCount,\n    senderEmail: subInput.senderEmail,\n    emailSubject: subInput.emailSubject,\n    emailId: subInput.emailId,\n    receivedAt: subInput.receivedAt,\n    businessCenter: submissionInput.businessCenter,\n    emailBodyHtml: subInput.emailBodyHtml || '',\n    verificationIssues: subInput.verificationIssues || []\n  },\n  binary: binary\n}];\n"
