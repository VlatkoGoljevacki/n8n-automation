      "parameters": {
        "jsCode": "const validationResult = $input.first().json;\nconst subInput = $('Sub-Workflow Input').first().json;\nconst config = subInput.config;\n\nconst cleanedLines = (validationResult.validatedLines || []).map(line => {\n  const { rawData, ...rest } = line;\n  return rest;\n});\n\nreturn [{\n  json: {\n    config: config,\n    validated: validationResult.validated,\n    lineCount: validationResult.lineCount,\n    summary: validationResult.summary,\n    validatedLines: cleanedLines,\n    invalidLines: (validationResult.invalidLines || []).map(line => {\n      const { rawData, ...rest } = line;\n      return rest;\n    }),\n    senderEmail: subInput.senderEmail,\n    emailSubject: subInput.emailSubject,\n    emailId: subInput.emailId,\n    receivedAt: subInput.receivedAt,\n    businessCenter: config.businessCenterDefault\n  }\n}];\n"
