    {
      "parameters": {
        "jsCode": "// Build Graph API sendMail payload for error notification\nconst config = $('Set Config').first().json;\nconst subInput = $('Sub-Workflow Input').first().json;\nconst binary = $('Sub-Workflow Input').first().binary || {};\nconst binaryKeys = Object.keys(binary);\n\nconst errorMsg = config.error || 'Unknown error';\nconst emailSubject = subInput.emailSubject || 'N/A';\nconst senderEmail = subInput.senderEmail || 'unknown';\nconst emailBodyHtml = subInput.emailBodyHtml || '';\n\nlet html = `<div style=\"padding:12px 16px;background:#f8d7da;color:#721c24;border-radius:6px;margin-bottom:16px;font-weight:bold;\">`;\nhtml += `ORDER PROCESSING ERROR`;\nhtml += `</div>`;\nhtml += `<p><strong>Error:</strong> ${errorMsg}</p>`;\nhtml += `<p><strong>From:</strong> ${senderEmail}<br>`;\nhtml += `<strong>Subject:</strong> ${emailSubject}</p>`;\n\nif (emailBodyHtml) {\n  html += `<hr style=\"margin:20px 0;\">`;\n  html += `<h3>Original Email</h3>`;\n  html += `<blockquote style=\"border-left:3px solid #ccc;padding:8px 16px;margin:8px 0;color:#555;\">${emailBodyHtml}</blockquote>`;\n}\n\nconst message = {\n  subject: `WF-09 Error: ${emailSubject}`,\n  body: { contentType: 'HTML', content: html },\n  toRecipients: [{ emailAddress: { address: config.notificationEmail } }]\n};\n\nif (binaryKeys.length > 0) {\n  message.attachments = binaryKeys.map(key => {\n    const att = binary[key];\n    return {\n      '@odata.type': '#microsoft.graph.fileAttachment',\n      name: att.fileName || 'attachment',\n      contentType: att.mimeType || 'application/octet-stream',\n      contentBytes: att.data\n    };\n  });\n}\n\nreturn [{ json: { sendMailPayload: { message } } }];\n"
      },
