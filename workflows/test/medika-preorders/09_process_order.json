        "jsCode": "// Output one item per unique delivery place ID for individual DT lookups\nconst input = $input.first().json;\nconst orderLines = input.orderLines || [];\nconst accessToken = input.accessToken;\n\nconst ids = [...new Set(orderLines.map(l => l.pharmacyId).filter(Boolean))];\n\n// Output one item per delivery place ID\nreturn ids.map(id => ({ json: { deliveryPlaceId: String(id), accessToken, parseResult: input } }));"
