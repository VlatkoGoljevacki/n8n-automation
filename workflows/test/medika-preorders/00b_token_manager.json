      "id": "f0b00000-0000-4000-8000-000000000006",
      "name": "Fetch Token"
    },
    {
      "parameters": {
        "jsCode": "// Parse token response and format for Data Table storage\nconst tokenResponse = $input.first().json;\nconst tokenType = $('Check Token').first().json.tokenType || 'medika_erp';\nconst token = tokenResponse.access_token;\nif (!token) {\n  throw new Error('Failed to get ' + tokenType + ' token: ' + JSON.stringify(tokenResponse));\n}\n\nlet expiresAt;\nif (tokenResponse['.expires']) {\n  expiresAt = new Date(tokenResponse['.expires']).toISOString();\n} else if (tokenResponse.expires_in) {\n  expiresAt = new Date(Date.now() + (tokenResponse.expires_in * 1000)).toISOString();\n} else {\n  expiresAt = new Date(Date.now() + (60 * 60 * 1000)).toISOString();\n}\n\nreturn [{ json: {\n  tokenType: tokenType,\n  token: token,\n  expiresAt: expiresAt,\n  storedAt: new Date().toISOString(),\n  accessToken: token\n}}];\n"
      },
