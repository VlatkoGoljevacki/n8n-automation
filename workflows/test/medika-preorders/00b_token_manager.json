      "id": "f0b00000-0000-4000-8000-000000000002",
      "name": "DT: Read Token",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Check Data Table for a valid cached token\n// DT: Read Token returns at most 1 row filtered by type, sorted by storedAt\nlet config;\ntry { config = $('Graph Config').first().json; } catch(e) { config = $('ERP Config').first().json; }\nconst tokenType = config.tokenType || 'medika_erp';\nconst tokenUrl = config.tokenUrl;\nconst tokenBody = config.tokenBody;\n\nconst dtRows = $('DT: Read Token').all();\nconst latest = dtRows.length > 0 ? dtRows[0].json : null;\n\nif (latest && latest.token && latest.expiresAt) {\n  const bufferMs = 10 * 60 * 1000;\n  const expiresAt = new Date(latest.expiresAt).getTime();\n  if (Date.now() < (expiresAt - bufferMs)) {\n    return [{ json: {\n      needsFetch: false,\n      accessToken: latest.token,\n      expiresAt: latest.expiresAt\n    }}];\n  }\n}\n\nreturn [{ json: {\n  needsFetch: true,\n  tokenType: tokenType,\n  tokenUrl: tokenUrl,\n  tokenBody: tokenBody\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1248,
        0
      ],
