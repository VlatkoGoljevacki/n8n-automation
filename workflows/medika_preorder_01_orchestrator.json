      "parameters": {
        "jsCode": "// Check static data for a valid (non-expired) ERP token\nconst staticData = $getWorkflowStaticData('global');\n\nif (staticData.erpToken && staticData.erpTokenExpiresAt) {\n  const bufferMs = 5 * 60 * 1000;\n  if (Date.now() < (staticData.erpTokenExpiresAt - bufferMs)) {\n    return [{ json: { erpToken: staticData.erpToken, tokenCacheHit: true }, binary: $input.first().binary }];\n  }\n}\n\nreturn [{ json: { erpToken: null, tokenCacheHit: false }, binary: $input.first().binary }];\n"
      },
