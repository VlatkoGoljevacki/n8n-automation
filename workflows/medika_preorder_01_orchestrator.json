        "jsCode": "// Build OAuth2 token request\nconst config = $('Config').first().json;\n\nreturn [{\n  json: {\n    tokenUrl: config.erpApiUrl + '/Token',\n    tokenBody: 'grant_type=password&username=' + encodeURIComponent(config.erpUsername) + '&password=' + encodeURIComponent(config.erpPassword)\n  },\n  binary: $input.first().binary\n}];\n"
