    {
      "parameters": {
        "jsCode": "// Re-attach binary data from trigger and carry config + customer data\nconst emailMeta = $('Extract Email Metadata').first().json;\nconst sv = $('WF-02: Validate Sender').first().json;\nconst config = $('Config').first().json;\n\n// Get binary directly from trigger node (binary gets dropped by Set/IF/Execute nodes)\nconst binary = $('New Email Received').first().binary || {};\nconst binaryKeys = Object.keys(binary);\nconst renamedBinary = {};\nif (binaryKeys.length > 0) {\n  // Rename first attachment to 'data' for Spreadsheet File node\n  renamedBinary.data = binary[binaryKeys[0]];\n  for (let i = 1; i < binaryKeys.length; i++) {\n    renamedBinary[binaryKeys[i]] = binary[binaryKeys[i]];\n  }\n}\n\nreturn [{\n  json: {\n    config: config,\n    senderEmail: emailMeta.senderEmail,\n    emailSubject: emailMeta.emailSubject,\n    emailId: emailMeta.emailId,\n    receivedAt: emailMeta.receivedAt,\n    senderName: sv.senderName || '',\n    customer: sv.customer || null,\n    deliveryPlace: sv.deliveryPlace || null,\n    businessCenter: sv.businessCenter || config.businessCenterDefault,\n    defaultDiscountPerc: sv.defaultDiscountPerc || config.defaultDiscountPerc\n  },\n  binary: renamedBinary\n}];\n"
